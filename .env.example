# convert2md environment file. See README.md for precedence and full docs.
# Copy to `.env` (project) or `~/.config/convert2md/.env` (user).

# --- Core ---
# OUTPUT=out.md
# CONCURRENCY=4
# FETCH_TIMEOUT_S=30
# CONVERTER_TIMEOUT_S=300

# --- Image handling (URL + PDF assets) ---
# INLINE_IMAGES=true            # false to keep original src URLs instead of data: URIs
# MIN_IMAGE_BYTES=1024
# MAX_IMAGE_BYTES=2000000

# --- URL crawling. Lists accept JSON or comma-separated values. ---
# CRAWL_DEPTH=0                 # 0..3
# MAX_PAGES=25                  # 1..500
# FOLLOW='["/docs/.*","/api/.*"]'
# EXCLUDE='logout,signup,\?.*$'

# --- Git tree filtering (frozensets; provide as JSON arrays). ---
# GIT_INCLUDED_EXTENSIONS='[".py",".md",".ts"]'
# GIT_INCLUDED_FILENAMES='["Dockerfile",".env.example"]'
# GIT_EXCLUDED_DIRS='[".git","node_modules","docs/references"]'
# GIT_EXCLUDED_FILES='["uv.lock","package-lock.json"]'
# GIT_CONVERT_IPYNB=true        # render .ipynb cells as Markdown instead of raw JSON
# GIT_CLEAN_MARKDOWN=true       # strip frontmatter / MDX imports / inline HTML from .md(x)

# --- PDF OCR. Engine: tesseract (offline) or gemini (needs GOOGLE_API_KEY). ---
# PDF_OCR=false
# PDF_OCR_ENGINE=tesseract      # tesseract | gemini
# PDF_OCR_LANGUAGE=eng          # tesseract only
# PDF_OCR_DPI=150               # 72..600, tesseract render
# PDF_OCR_RENDER_DPI=220        # 72..600, gemini page render

# --- Headless browser (URL converter via crawl4ai). ---
# BROWSER_HEADLESS=true
# BROWSER_TIMEOUT_MS=30000      # 1000..300000

# --- YouTube transcripts. Languages are tried in order. ---
# YOUTUBE_LANGUAGES=en,de
# YOUTUBE_WEBSHARE_PROXY_USERNAME=
# YOUTUBE_WEBSHARE_PROXY_PASSWORD=

# --- Gemini. Requires `pip install convert2md[gemini]`. ---
# GOOGLE_API_KEY=                # https://aistudio.google.com/app/apikey
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_CONCURRENCY=4           # 1..32 — parallel Gemini calls
# DESCRIBE_IMAGES=false          # true => caption every collected image asset
# AI_EXTRACT=false               # true => screenshot rendered URL/image and append visual transcription
# TRANSCRIBE_PROMPT_FILE=        # optional path; overrides convert2md/prompts/transcribe.md
# CAPTION_PROMPT_FILE=           # optional path; overrides convert2md/prompts/caption.md
